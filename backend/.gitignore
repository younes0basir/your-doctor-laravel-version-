# Laravel Backend .gitignore

# Environment files
.env
.env.backup
.env.production
.phpunit.result.cache

# Dependencies
/vendor/
node_modules/

# Build artifacts
/public/hot
/public/storage
/storage/*.key

# Logs
/storage/logs/*.log
npm-debug.log
yarn-error.log

# Framework files
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*

# IDE files
/.idea
/.vscode
*.swp
*.swo
*~
.DS_Store

# Testing
/phpunit.xml
/tests/coverage/

# Compiled files
/bootstrap/cache/*
!/bootstrap/cache/.gitkeep

/database/*.sqlite
/database/*.sqlite-journal
/database/database.sqlite

# Backup files
*.bak
*.backup

# OS files
Thumbs.db
